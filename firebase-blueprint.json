{
  "entities": {
    "Admin": {
      "title": "Administrator",
      "description": "A user with administrative privileges",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the administrator"
        },
        "addedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the admin was added"
        },
        "addedBy": {
          "type": "string",
          "description": "UID of the admin who added this one"
        }
      },
      "required": ["email", "addedAt"]
    },
    "SavedStrategy": {
      "title": "Saved Strategy",
      "description": "A course strategy saved by a user",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the owner"
        },
        "strategy": {
          "type": "object",
          "description": "The course strategy data"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the strategy was saved"
        }
      },
      "required": ["uid", "strategy", "createdAt"]
    },
    "AppMetric": {
      "title": "App Metric",
      "description": "Recorded event for usage tracking",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Event type (e.g., strategy_generated, search, download)"
        },
        "uid": {
          "type": "string",
          "description": "User ID who performed the action"
        },
        "details": {
          "type": "object",
          "description": "Contextual details for the event"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the event occurred"
        }
      },
      "required": ["type", "timestamp"]
    }
  },
  "firestore": {
    "/admin_emails/{emailId}": {
      "schema": "Admin",
      "description": "Collection of authorized administrator emails"
    },
    "/saved_strategies/{strategyId}": {
      "schema": "SavedStrategy",
      "description": "Collection of saved course strategies"
    },
    "/app_metrics/{metricId}": {
      "schema": "AppMetric",
      "description": "Usage logs for analytics"
    },
    "/saved_strategies/{strategyId}/versions/{versionId}": {
      "schema": "SavedStrategy",
      "description": "History of versions for a strategy"
    }
  }
}
