rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: saved_strategies
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user ID of the owner
    //   - strategy: map (required) - The course strategy data
    //   - createdAt: timestamp (required) - When the strategy was saved
    //   - updatedAt: timestamp (optional) - When the strategy was last updated
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAllowedByTime() {
      // time based on 1776639600000 (April 2026)
      return request.time < timestamp.value(1776639600000);
    }

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admin_emails/$(request.auth.token.email)) ||
        request.auth.token.email == "gloria@cademmy.com" ||
        request.auth.token.email == "gloriaalbamx@google.com"
      );
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidStrategy(data) {
      return data.keys().hasAny(['uid', 'strategy', 'createdAt']) &&
             data.uid is string &&
             data.strategy is map &&
             data.createdAt is timestamp;
    }

    function isParentOwner(strategyId) {
      return isAuthenticated() && get(/databases/$(database)/documents/saved_strategies/$(strategyId)).data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /saved_strategies/{strategyId} {
      allow read: if isDocOwner() || isAdmin() || isAllowedByTime();
      allow create: if (isAuthenticated() && uidUnchanged() && isValidStrategy(request.resource.data)) || isAllowedByTime();
      allow delete: if isDocOwner() || isAdmin() || isAllowedByTime();
      allow update: if (isDocOwner() && uidUnchanged() && isValidStrategy(request.resource.data)) || isAllowedByTime();

      match /versions/{versionId} {
        allow read: if isParentOwner(strategyId) || isAdmin() || isAllowedByTime();
        allow create: if (isParentOwner(strategyId) && isValidStrategy(request.resource.data)) || isAllowedByTime();
      }
    }

    match /admin_emails/{emailId} {
      allow read: if isAuthenticated() || isAllowedByTime();
      allow write: if isAdmin() || isAllowedByTime();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAllowedByTime();
    }
  }
}
